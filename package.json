{
	"dependencies": {
		"prettier-plugin-go-template": "^0.0.15"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-go-template"
		],
		"overrides": [
			{
				"files": [
					"*.html"
				],
				"options": {
					"parser": "go-template"
				}
			}
		]
	},
	"devDependencies": {
		"prettier": "^3.8.1",
		"prettier-plugin-hugo-post": "^0.4.1"
	}
}
